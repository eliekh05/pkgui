{
  "name": "@eliekh05/pkgui",
  "version": "1.0.0",
  "description": "Universal Package Manager GUI — xterm.js powered terminal UI for 40+ package managers",
  "type": "module",
  "bin": {
    "pkgui": "bin/pkgui"
  },
  "files": [
    "bin",
    "server.js",
    "pkgui.html",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eliekh05/pkgui.git"
  },
  "homepage": "https://github.com/eliekh05/pkgui#readme",
  "bugs": {
    "url": "https://github.com/eliekh05/pkgui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "server": "node server.js --open",
    "start": "node server.js --open",
    "prepare:npm": "node scripts/prepare-npm.mjs",
    "prepublishOnly": "npm test && node scripts/prepare-npm.mjs"
  },
  "keywords": ["package-manager", "xterm", "terminal", "gui", "cli"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^6.0.1",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
